{
  "openapi": "3.0.0",
  "info": {
    "title": "SafeHand Payments & Payouts API",
    "description": "API documentation for client payments and worker payouts. Includes daily due alerts and attendance-based salary tracking.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Development Server"
    }
  ],
  "tags": [
    {
      "name": "Client Payments",
      "description": "Managing payments received from clients."
    },
    {
      "name": "Worker Payouts",
      "description": "Managing payments sent to workers based on attendance."
    }
  ],
  "paths": {
    "/api/payments": {
      "post": {
        "summary": "Create Client Payment",
        "tags": ["Client Payments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["jobCardId", "amount"],
                "properties": {
                  "jobCardId": { "type": "string", "example": "65b9dbf8..." },
                  "amount": { "type": "number", "example": 5000 },
                  "paymentMethod": { "type": "string", "enum": ["cash", "card", "upi"], "example": "upi" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Payment Created Successfully" }
        }
      },
      "get": {
        "summary": "Get All Client Payments",
        "tags": ["Client Payments"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/payments/due/today": {
      "get": {
        "summary": "Get Today's Due Client Payments",
        "description": "Returns a list of clients who need to pay today based on service elapsed time vs amount paid.",
        "tags": ["Client Payments"],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/payments/jobcard/{jobCardId}": {
      "get": {
        "summary": "Get Payments by JobCard ID",
        "tags": ["Client Payments"],
        "parameters": [
          { "name": "jobCardId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/worker-payouts": {
      "post": {
        "summary": "Create Worker Payout",
        "tags": ["Worker Payouts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["workerId", "jobCardId", "amount"],
                "properties": {
                  "workerId": { "type": "string", "example": "65b9dbf8..." },
                  "jobCardId": { "type": "string", "example": "65b9dbf8..." },
                  "amount": { "type": "number", "example": 2000 },
                  "remarks": { "type": "string", "example": "Week 1 Payout" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Payout Created" } }
      }
    },
    "/api/worker-payouts/due": {
      "get": {
        "summary": "Get Worker Due Balance",
        "description": "Calculates the total earned amount based on 'present' attendance records and subtracts previous payouts.",
        "tags": ["Worker Payouts"],
        "parameters": [
          { "name": "workerId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "jobCardId", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/worker-payouts/history/{workerId}": {
      "get": {
        "summary": "Get Worker Payout History",
        "tags": ["Worker Payouts"],
        "parameters": [
          { "name": "workerId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Success" } }
      }
    }
  }
}
