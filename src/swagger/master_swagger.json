                  "jobCardId",
                  "amount"
                ],
                "properties": {
                  "workerId": {
                    "type": "string",
                    "example": "65b9dbf8a7c21a..."
                  },
                  "jobCardId": {
                    "type": "string",
                    "example": "65b9dbf8a7c23a..."
                  },
                  "amount": {
                    "type": "number",
                    "example": 5000
                  }
                }
              }
            }
          }
        },
        "responses": {
