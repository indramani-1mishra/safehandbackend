    "/api/workers/create": {
      "post": {
        "summary": "Create a new Worker",
        "tags": [
          "Workers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "age": {
                    "type": "integer"
                  },
                  "gender": {
                    "type": "string",
                    "enum": [
                      "male",
                      "female",
                      "other"
                    ]
                  },
                  "city": {
                    "type": "string"
                  },
                  "services": {
                    "type": "string",
                    "description": "JSON string"
                  },
                  "image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "documents": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                },
                "required": [
                  "name",
                  "email",
                  "phone"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Worker created successfully"
          },
          "400": {
            "description": "Validation error or App Error"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
