            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful retrieval"
          }
        }
      }
    },
    "/api/attendance/request-otp": {
      "post": {
        "summary": "Request Attendance OTP",
        "tags": [
          "Attendance (Worker)"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "jobCardId",
                  "workerId"
                ],
                "properties": {
                  "jobCardId": {
                    "type": "string",
                    "example": "65b9dbf8a7c23a..."
                  },
                  "workerId": {
                    "type": "string",
                    "example": "65b9dbf8a7c21a..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP Sent Successfully"
          }
        }
      }
    },
    "/api/attendance/verify-otp": {
      "post": {
        "summary": "Verify Attendance OTP",
        "tags": [
          "Attendance (Worker)"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "jobCardId",
                  "workerId",
                  "otp"
                ],
                "properties": {
                  "jobCardId": {
                    "type": "string",
                    "example": "65b9dbf8a7c23a..."
                  },
                  "workerId": {
                    "type": "string",
                    "example": "65b9dbf8a7c21a..."
                  },
                  "otp": {
                    "type": "string",
                    "example": "123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attendance Verified and Created"
          }
        }
      }
    },
