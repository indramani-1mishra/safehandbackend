                "properties": {
                  "inquiryId": {
                    "type": "string",
                    "example": "65b9dbf8a7c23a... "
                  },
                  "patientDetails": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "example": "John Doe"
                      },
                      "age": {
                        "type": "number",
                        "example": 45
                      },
                      "gender": {
                        "type": "string",
                        "example": "male"
                      },
                      "address": {
                        "type": "string",
                        "example": "123 Main St"
                      },
                      "city": {
                        "type": "string",
                        "example": "Mumbai"
                      },
                      "phone": {
                        "type": "string",
                        "example": "9876543210"
                      }
                    }
                  },
                  "serviceDetails": {
                    "type": "object",
                    "properties": {
                      "service": {
                        "type": "string",
                        "example": "65b9... "
                      },
                      "plan": {
                        "type": "string",
                        "example": "basic"
                      },
                      "duration": {
                        "type": "number",
                        "example": 3
                      },
                      "timing": {
                        "type": "string",
                        "example": "12hr"
                      }
                    }
                  },
                  "addons": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string",
                          "example": "Physiotherapy"
                        },
                        "price": {
                          "type": "number",
                          "example": 500
                        }
                      }
                    }
                  },
                  "totalPrice": {
                    "type": "number",
                    "example": 3500
                  },
                  "isDirectAssignWorker": {
                    "type": "boolean",
                    "example": false
                  },
                  "assignedWorkerId": {
                    "type": "string",
                    "example": "65b9..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Job Card Created"
          }
        }
      }
