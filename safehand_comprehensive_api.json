{
  "openapi": "3.0.0",
  "info": {
    "title": "SafeHand Comprehensive Master API",
    "description": "Full-stack documentation for SafeHand Backend. All fields from Models included.",
    "version": "1.0.0"
  },
  "servers": [{ "url": "http://localhost:3000", "description": "Local Dev" }],
  "tags": [
    { "name": "Admin Operations", "description": "Admin users and auth" },
    { "name": "Worker Operations", "description": "Worker profiles and auth" },
    { "name": "Client Services", "description": "Enquiries and Service Catalog" },
    { "name": "Job Operations", "description": "JobCards and Assignment" },
    { "name": "Attendance & Finance", "description": "Attendance, Payments, and Payouts" }
  ],
  "components": {
    "schemas": {
      "PatientDetails": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "example": "Indramani Mishra" },
          "age": { "type": "number", "example": 25 },
          "gender": { "type": "string", "enum": ["male", "female", "other"] },
          "address": { "type": "string", "example": "Mumbai, MH" },
          "city": { "type": "string", "example": "Mumbai" },
          "phone": { "type": "string", "example": "9876543210" }
        }
      },
      "ServiceDetails": {
        "type": "object",
        "properties": {
          "service": { "type": "string", "description": "Service ObjectID" },
          "plan": { "type": "string", "enum": ["basic", "advance"] },
          "timing": { "type": "string", "example": "12hr" }
        }
      },
      "JobCard": {
        "type": "object",
        "properties": {
          "inquiryId": { "type": "string" },
          "patientDetails": { "$ref": "#/components/schemas/PatientDetails" },
          "serviceDetails": { "$ref": "#/components/schemas/ServiceDetails" },
          "serviceStart": { "type": "string", "format": "date" },
          "serviceEnd": { "type": "string", "format": "date" },
          "totalDealAmount": { "type": "number" },
          "perDayCustomerCost": { "type": "number" },
          "customerPaymentCycleDays": { "type": "integer" },
          "totalNurseSalary": { "type": "number" },
          "perDayNurseCost": { "type": "number" },
          "nursePaymentCycleDays": { "type": "integer" },
          "workers": {
            "type": "object",
            "properties": {
              "assigned": { "type": "string", "description": "Worker ID" }
            }
          }
        }
      },
      "ClientPayment": {
        "type": "object",
        "properties": {
          "jobCardId": { "type": "string" },
          "amount": { "type": "number" },
          "paymentMethod": { "type": "string", "enum": ["cash", "card", "upi"] },
          "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"] },
          "dayCovered": { "type": "number" },
          "remainingAmount": { "type": "number" },
          "remainingDays": { "type": "number" },
          "paidUntilDate": { "type": "string", "format": "date" },
          "reachLimit": { "type": "boolean" },
          "overLimit": { "type": "boolean" }
        }
      }
    }
  },
  "paths": {
    "/api/jobcards": {
      "post": {
        "summary": "Create Full JobCard",
        "tags": ["Job Operations"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/JobCard" } } } },
        "responses": { "201": { "description": "Success" } }
      }
    },
    "/api/payments": {
      "post": {
        "summary": "Record Client Payment with Metadata",
        "tags": ["Attendance & Finance"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClientPayment" } } } },
        "responses": { "201": { "description": "Success" } }
      }
    },
    "/api/dashboard/summary": {
      "get": {
        "summary": "Full Admin Dashboard Report",
        "tags": ["Attendance & Finance"],
        "responses": { "200": { "description": "Returns financial summary" } }
      }
    },
    "/api/attendance/verify-otp": {
      "post": {
        "summary": "Mark Attendance (Worker)",
        "tags": ["Attendance & Finance"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "jobCardId": { "type": "string" }, "workerId": { "type": "string" }, "otp": { "type": "string" } } } } } },
        "responses": { "201": { "description": "Success" } }
      }
    }
  }
}
