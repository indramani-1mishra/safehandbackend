{
  "openapi": "3.0.0",
  "info": {
    "title": "SafeHand API Collection",
    "version": "1.0.0",
    "description": "API documentation for Admin, Services, and Enquiries endpoints"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local Development Server"
    }
  ],
  "tags": [
    {
      "name": "Admin",
      "description": "Admin Operations"
    },
    {
      "name": "Services",
      "description": "Service Operations"
    },
    {
      "name": "Enquiries",
      "description": "Enquiry Operations"
    }
  ],
  "paths": {
    "/admins/create": {
      "post": {
        "summary": "Create an Admin",
        "tags": [
          "Admin"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Admin created successfully"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/admins/update/{id}": {
      "put": {
        "summary": "Update an Admin",
        "tags": [
          "Admin"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admin updated successfully"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/admins/getall": {
      "get": {
        "summary": "Get all Admins",
        "tags": [
          "Admin"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/admins/get/{id}": {
      "get": {
        "summary": "Get Admin by ID",
        "tags": [
          "Admin"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/admins/delete/{id}": {
      "delete": {
        "summary": "Delete an Admin",
        "tags": [
          "Admin"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Admin deleted successfully"
          }
        }
      }
    },
    "/admins/makeadmin/{id}": {
      "post": {
        "summary": "Make a user Admin",
        "tags": [
          "Admin"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Role updated to admin"
          }
        }
      }
    },
    "/services/create": {
      "post": {
        "summary": "Create a Service",
        "tags": [
          "Services"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "pricingByCity": {
                    "type": "string",
                    "description": "JSON string"
                  },
                  "basicFeatures": {
                    "type": "string",
                    "description": "JSON string arrays"
                  },
                  "advanceFeatures": {
                    "type": "string",
                    "description": "JSON string arrays"
                  },
                  "addons": {
                    "type": "string",
                    "description": "JSON string format"
                  },
                  "image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "basicImage": {
                    "type": "string",
                    "format": "binary"
                  },
                  "advanceImage": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Service created successfully"
          },
          "400": {
            "description": "Error creating service"
          }
        }
      }
    },
    "/services/findservice": {
      "get": {
        "summary": "Find Service Names and Images",
        "tags": [
          "Services"
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/services/update/{id}": {
      "patch": {
        "summary": "Update a Service",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "pricingByCity": {
                    "type": "string"
                  },
                  "basicFeatures": {
                    "type": "string"
                  },
                  "advanceFeatures": {
                    "type": "string"
                  },
                  "addons": {
                    "type": "string"
                  },
                  "image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "basicImage": {
                    "type": "string",
                    "format": "binary"
                  },
                  "advanceImage": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Service updated successfully"
          }
        }
      }
    },
    "/services/getall": {
      "get": {
        "summary": "Get all Services",
        "tags": [
          "Services"
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/services/get/{id}": {
      "get": {
        "summary": "Get Service by ID",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/services/delete/{id}": {
      "delete": {
        "summary": "Delete a Service",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Service deleted successfully"
          }
        }
      }
    },
    "/enqueries/": {
      "post": {
        "summary": "Create an Enquiry",
        "tags": [
          "Enquiries"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "phone": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "enquiryType": {
                    "type": "string"
                  },
                  "patientName": {
                    "type": "string"
                  },
                  "address": {
                    "type": "string"
                  },
                  "startDate": {
                    "type": "string"
                  },
                  "service": {
                    "type": "string"
                  },
                  "serviceDuration": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Enquiry created successfully"
          }
        }
      },
      "get": {
        "summary": "Get all Enquiries",
        "tags": [
          "Enquiries"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "type",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "status",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/enqueries/{id}": {
      "get": {
        "summary": "Get Enquiry by ID",
        "tags": [
          "Enquiries"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      },
      "put": {
        "summary": "Update Enquiry",
        "tags": [
          "Enquiries"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "phone": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Enquiry updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete an Enquiry",
        "tags": [
          "Enquiries"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Enquiry deleted successfully"
          }
        }
      }
    },
    "/enqueries/{id}/status": {
      "patch": {
        "summary": "Update Enquiry Status",
        "tags": [
          "Enquiries"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "pending",
                      "approved",
                      "rejected"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated successfully"
          }
        }
      }
    },
    "/enqueries/status/{status}": {
      "get": {
        "summary": "Get Enquiries by Status",
        "tags": [
