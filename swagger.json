          }
        }
      }
    },
    "/enqueries/type/{type}": {
      "get": {
        "summary": "Get Enquiries by Type",
        "tags": [
          "Enquiries"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "type",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/enqueries/type/{type}/status/{status}": {
      "get": {
        "summary": "Get Enquiries by Type and Status",
        "tags": [
          "Enquiries"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "type",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "status",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    }
  }
}