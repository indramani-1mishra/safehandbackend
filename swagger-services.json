{
  "openapi": "3.0.0",
  "info": {
    "title": "SafeHand Service API",
    "description": "API Documentation for Service operations including AWS Image Upload.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "paths": {
    "/api/services/create": {
      "post": {
        "summary": "Create a new Service",
        "tags": ["Services"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Name of the service (required)",
                    "example": "Expert Plumber"
                  },
                  "description": {
                    "type": "string",
                    "description": "Description of the service",
                    "example": "Best plumbing in town"
                  },
                  "pricingByCity": {
                    "type": "string",
                    "description": "Array of city pricing as JSON string",
                    "example": "[{\"city\":\"Delhi\",\"basic\":{\"hr12\":500,\"hr24\":900},\"advance\":{\"hr12\":800,\"hr24\":1500}}]"
                  },
                  "basicFeatures": {
                    "type": "string",
                    "description": "Basic features array as JSON string",
                    "example": "[\"Cleaning\",\"Repair\"]"
                  },
                  "advanceFeatures": {
                    "type": "string",
                    "description": "Advance features array as JSON string",
                    "example": "[\"Deep Clean\",\"Free Spares\"]"
                  },
                  "addons": {
                    "type": "string",
                    "description": "Array of Addons as JSON string",
                    "example": "[{\"name\":\"Pipes\",\"price\":200}]"
                  },
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Main cover image file (required)"
                  },
                  "basicImage": {
                    "type": "string",
                    "format": "binary",
                    "description": "Basic plan image file"
                  },
                  "advanceImage": {
                    "type": "string",
                    "format": "binary",
                    "description": "Advance plan image file"
                  }
                },
                "required": ["name", "image"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Service successfully created"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/services/getall": {
      "get": {
        "summary": "Get all Services",
        "tags": ["Services"],
        "responses": {
          "200": {
            "description": "A JSON array of all services"
          }
        }
      }
    },
    "/api/services/get/{id}": {
      "get": {
        "summary": "Get a specific Service by ID",
        "tags": ["Services"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Mongoose Object ID of the service"
          }
        ],
        "responses": {
          "200": {
            "description": "Specific service returned"
          },
          "404": {
            "description": "Service not found"
          }
        }
      }
    },
    "/api/services/update/{id}": {
      "put": {
        "summary": "Update an existing Service",
        "tags": ["Services"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Mongoose Object ID of the service to update"
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "pricingByCity": {
                    "type": "string"
                  },
                  "basicFeatures": {
                    "type": "string"
                  },
                  "advanceFeatures": {
                    "type": "string"
                  },
                  "image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "basicImage": {
                    "type": "string",
                    "format": "binary"
                  },
                  "advanceImage": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Service updated successfully"
          }
        }
      }
    },
    "/api/services/delete/{id}": {
      "delete": {
        "summary": "Delete a specific Service",
        "tags": ["Services"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Mongoose Object ID of the service"
          }
        ],
        "responses": {
          "200": {
            "description": "Service deleted successfully"
          }
        }
      }
    }
  }
}
