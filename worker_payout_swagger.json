{
  "openapi": "3.0.0",
  "info": {
    "title": "SafeHand - Worker Payout APIs",
    "version": "1.0.0",
    "description": "API documentation for managing worker balances and payout requests."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Development Server"
    }
  ],
  "tags": [
    {
      "name": "Worker Payout",
      "description": "Endpoints for workers to request and track payments."
    }
  ],
  "paths": {
    "/api/worker-payouts/request": {
      "post": {
        "summary": "Worker: Request a payout",
        "tags": [
          "Worker Payout"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "workerId",
                  "jobCardId",
                  "amount"
                ],
                "properties": {
                  "workerId": {
                    "type": "string",
                    "example": "65b9dbf8a7c21a..."
                  },
                  "jobCardId": {
                    "type": "string",
                    "example": "65b9dbf8a7c23a..."
                  },
                  "amount": {
                    "type": "number",
                    "example": 5000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payout request sent successfully"
          },
          "400": {
            "description": "Insufficient balance or invalid input"
          }
        }
      }
    },
    "/api/worker-payouts/balance": {
      "get": {
        "summary": "Worker: Get balance breakdown for a specific job",
        "tags": [
          "Worker Payout"
        ],
        "parameters": [
          {
            "name": "workerId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "jobCardId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detailed breakdown of earnings, paid, and pending amounts"
          }
        }
      }
    },
    "/api/worker-payouts/pending": {
      "get": {
        "summary": "Admin: Get all pending payout requests",
        "tags": [
          "Worker Payout"
        ],
        "responses": {
          "200": {
            "description": "List of all worker requests awaiting approval"
          }
        }
      }
    },
    "/api/worker-payouts/admin/summary": {
      "get": {
        "summary": "Admin: Get summary of all worker payables across all jobs",
        "tags": [
          "Worker Payout"
        ],
        "parameters": [
          {
            "name": "hasPendingRequest",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false"
              ]
            }
          },
          {
            "name": "cycleOverdue",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false"
              ]
            }
          },
          {
            "name": "minBalance",
            "in": "query",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Filterable list of workers and their due amounts"
          }
        }
      }
    },
    "/api/worker-payouts/paid": {
      "get": {
        "summary": "Admin: Get all successfully paid/approved payouts",
        "tags": [
          "Worker Payout"
        ],
        "responses": {
          "200": {
            "description": "History of approved payouts"
          }
        }
      }
    },
    "/api/worker-payouts/approve/{id}": {
      "put": {
        "summary": "Admin: Approve a pending payout request",
        "tags": [
          "Worker Payout"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "transactionId": {
                    "type": "string",
                    "example": "TXN123456"
                  },
                  "remarks": {
                    "type": "string",
                    "example": "Approved via IMPS"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payout approved and status changed to 'paid'"
          }
        }
      }
    },
    "/api/worker-payouts": {
      "post": {
        "summary": "Admin: Create a manual payout (Mark as paid without request)",
        "tags": [
          "Worker Payout"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "workerId",
                  "jobCardId",
                  "amount",
                  "status"
                ],
                "properties": {
                  "workerId": {
                    "type": "string"
                  },
                  "jobCardId": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "number"
                  },
                  "status": {
                    "type": "string",
                    "example": "paid"
                  },
                  "remarks": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payout created successfully"
          }
        }
      }
    },
    "/api/worker-payouts/due": {
      "get": {
        "summary": "Get worker's current due balance (Legacy endpoint)",
        "tags": [
          "Worker Payout"
        ],
        "parameters": [
          {
            "name": "workerId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "jobCardId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Calculation of total earned vs total paid"
          }
        }
      }
    },
    "/api/worker-payouts/history/{workerId}": {
      "get": {
        "summary": "Get specific worker's entire payment history",
        "tags": [
          "Worker Payout"
        ],
        "parameters": [
          {
            "name": "workerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of all payouts (paid, pending, failed) for the worker"
          }
        }
      }
    }
  }
}
