{
  "openapi": "3.0.0",
  "info": {
    "title": "SafeHand Worker Payout API",
    "description": "API documentation for the SafeHand Worker Payout and Financial Management system. Includes payout requests, admin approvals, and balance summaries.",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "Worker Payout (Worker)",
      "description": "Endpoints for workers to request and track payments."
    },
    {
      "name": "Worker Payout (Admin)",
      "description": "Admin management for worker financials and approvals."
    }
  ],
  "paths": {
    "/api/worker-payouts/request": {
      "post": {
        "summary": "Request a Payout (Worker)",
        "tags": ["Worker Payout (Worker)"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["workerId", "jobCardId", "amount"],
                "properties": {
                  "workerId": { "type": "string", "example": "65b9dbf8a7c21a..." },
                  "jobCardId": { "type": "string", "example": "65b9dbf8a7c23a..." },
                  "amount": { "type": "number", "example": 500 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Payout request sent successfully" },
          "400": { "description": "Insufficient balance or invalid data" }
        }
      }
    },
    "/api/worker-payouts/balance": {
      "get": {
        "summary": "Get Worker Balance Breakdown",
        "tags": ["Worker Payout (Worker)"],
        "parameters": [
          { "name": "workerId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "jobCardId", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Detailed balance breakdown" }
        }
      }
    },
    "/api/worker-payouts/pending": {
      "get": {
        "summary": "Get All Pending Payout Requests (Admin)",
        "tags": ["Worker Payout (Admin)"],
        "responses": {
          "200": { "description": "List of pending requests" }
        }
      }
    },
    "/api/worker-payouts/paid": {
      "get": {
        "summary": "Get All Paid/Approved Payouts (Admin)",
        "tags": ["Worker Payout (Admin)"],
        "responses": {
          "200": { "description": "List of paid history" }
        }
      }
    },
    "/api/worker-payouts/approve/{id}": {
      "put": {
        "summary": "Approve a Payout Request (Admin)",
        "tags": ["Worker Payout (Admin)"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "paymentMethod": { "type": "string", "example": "upi" },
                  "remarks": { "type": "string", "example": "Paid via PhonePe" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Payout approved successfully" }
        }
      }
    },
    "/api/worker-payouts/admin/summary": {
      "get": {
        "summary": "Get Summary of All Worker Payables (Admin)",
        "tags": ["Worker Payout (Admin)"],
        "parameters": [
          { "name": "hasPendingRequest", "in": "query", "schema": { "type": "boolean" } },
          { "name": "cycleOverdue", "in": "query", "schema": { "type": "boolean" } },
          { "name": "minBalance", "in": "query", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "Comprehensive summary of worker financials" }
        }
      }
    },
    "/api/worker-payouts/history/{workerId}": {
      "get": {
        "summary": "Get Payout History for a Worker",
        "tags": ["Worker Payout (Worker)"],
        "parameters": [
          { "name": "workerId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of all previous payouts" }
        }
      }
    },
    "/api/worker-payouts/due": {
      "get": {
        "summary": "Check Current Due Balance (Legacy)",
        "tags": ["Worker Payout (Admin)"],
        "parameters": [
          { "name": "workerId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "jobCardId", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Simple due balance calculation" }
        }
      }
    }
  }
}
