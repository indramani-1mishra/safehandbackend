{
  "openapi": "3.0.0",
  "info": {
    "title": "SafeHand Ultimate API Collection",
    "description": "Comprehensive API documentation for Admin, Workers, Attendance, JobCards, Payments, and Financial Dashboard.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Development Server"
    }
  ],
  "tags": [
    { "name": "Auth", "description": "Authentication for Admin and Workers" },
    { "name": "Admins", "description": "Admin user management" },
    { "name": "Services", "description": "Service categories and pricing" },
    { "name": "Enquiries", "description": "Client service requests" },
    { "name": "JobCards", "description": "Job assignment and status tracking" },
    { "name": "Attendance", "description": "Daily OTP-verified attendance" },
    { "name": "Client Payments", "description": "Revenue tracking and coverage" },
    { "name": "Worker Payouts", "description": "Attendance-based payouts" },
    { "name": "Dashboard", "description": "Business financial overview" }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": { "type": "apiKey", "in": "cookie", "name": "adminToken" }
    },
    "schemas": {
      "ClientPayment": {
        "type": "object",
        "required": ["jobCardId", "amount"],
        "properties": {
          "jobCardId": { "type": "string", "example": "65b9db... " },
          "amount": { "type": "number", "example": 5000 },
          "paymentMethod": { "type": "string", "enum": ["cash", "card", "upi"], "default": "upi" }
        }
      },
      "WorkerPayout": {
        "type": "object",
        "required": ["workerId", "jobCardId", "amount"],
        "properties": {
          "workerId": { "type": "string", "example": "65b9..." },
          "jobCardId": { "type": "string", "example": "65b9..." },
          "amount": { "type": "number", "example": 2500 }
        }
      }
    }
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "summary": "Admin Login",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "email": { "type": "string" }, "password": { "type": "string" } } } } }
        },
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/payments": {
      "post": {
        "summary": "Record Client Payment",
        "tags": ["Client Payments"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClientPayment" } } } },
        "responses": { "201": { "description": "Payment Success" } }
      },
      "get": { "summary": "Get All Payments", "tags": ["Client Payments"], "responses": { "200": { "description": "List fetched" } } }
    },
    "/api/payments/due/today": {
      "get": {
        "summary": "Clients Due for Payment Today",
        "tags": ["Client Payments"],
        "description": "Lists clients where (Service Days > Paid Days). Real-time check.",
        "responses": { "200": { "description": "Due list fetched" } }
      }
    },
    "/api/worker-payouts/due": {
      "get": {
        "summary": "Check Worker Due Balance",
        "tags": ["Worker Payouts"],
        "parameters": [
          { "name": "workerId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "jobCardId", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/worker-payouts": {
      "post": {
        "summary": "Process Worker Payout",
        "tags": ["Worker Payouts"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorkerPayout" } } } },
        "responses": { "201": { "description": "Payout recorded" } }
      }
    },
    "/api/dashboard/summary": {
      "get": {
        "summary": "Financial Dashboard Summary",
        "tags": ["Dashboard"],
        "description": "Returns Revenue, Total Receivables, Total Payables, and Active Job stats.",
        "responses": { "200": { "description": "Dashboard data fetched" } }
      }
    },
    "/api/attendance/request-otp": {
      "post": {
        "summary": "Request OTP for Attendance",
        "tags": ["Attendance"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "jobCardId": { "type": "string" }, "workerId": { "type": "string" } } } } } },
        "responses": { "200": { "description": "OTP Sent" } }
      }
    },
    "/api/attendance/verify-otp": {
      "post": {
        "summary": "Verify OTP and mark present",
        "tags": ["Attendance"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "jobCardId": { "type": "string" }, "workerId": { "type": "string" }, "otp": { "type": "string" } } } } } },
        "responses": { "201": { "description": "Marked Present" } }
      }
    }
  }
}
